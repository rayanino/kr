# خزانة ريان (KR) — API Keys for Step 2 LLM Testing
# Copy this to .env and fill in your keys. .env is gitignored.
#
# Required for Phase 1 (prompt iteration):
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required for Phase 2 (multi-model testing):
OPENROUTER_API_KEY=sk-or-v1-...

# Optional (alternative to OpenRouter for Mistral):
MISTRAL_API_KEY=...
