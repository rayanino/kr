.cowork/

# ─── Claude Code local settings (personal, not shared) ──────────────
.claude/settings.local.json
.claude/changes.log
.claude/scheduled_tasks.lock
.claude/hooks/config/hooks-config.local.json
global-settings.json

# ─── Overnight system (regenerated each run) ─────────────────────────
overnight/decisions.log
overnight/state.json
overnight/state.json.tmp
overnight/progress.md
overnight/progress.md.tmp
overnight/MORNING_REPORT.md
overnight/MORNING_REPORT.md.tmp
overnight/results/

# ─── Frozen source files ─────────────────────────────────────────────
# Source files are large and frozen at intake time. They are stored locally
# but not tracked in version control. Each source's source_metadata.json
# contains SHA-256 hashes for integrity verification.
library/sources/frozen/

# ─── Pipeline outputs (regeneratable) ────────────────────────────────
output/

# ─── API keys and secrets ────────────────────────────────────────────
.env

# ─── Python ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/

# ─── Session prep (generated, not tracked) ───────────────────────────
vision_excerpt.md
session_bundle.md

# ─── Shamela export samples (local only) ─────────────────────
shamela-export-samples/

# ─── Serena IDE config (personal, not shared) ────────────────────────
.serena/

# ─── OS / Editor ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ─── recursive-improve traces (ephemeral, regeneratable) ────────────
eval/traces/
eval/benchmark_results.json
eval/ratchet_summary.md
eval/action_plan.md
eval/ri_decisions_*.json

# ─── Test results (per-engine, regeneratable) ────────────────────────
