  "scholarly_context": {
    "composition_period": "الفتاوى والرسائل كُتبت على مدار حياة ابن تيمية العلمية، من أواخر القرن السابع إلى أوائل القرن الثامن الهجري",
    "composition_date_hijri": null,
    "tradition_position": "أهم وأشمل مجموعة لفتاوى ورسائل ابن تيمية، جمعها ابن قاسم على مدى عقود من المخطوطات المتفرقة، وهي المرجع الأساسي لتراث ابن تيمية",
    "known_textual_issues": [
      "بعض الرسائل المدرجة قد تكون منسوبة خطأً أو مكررة",
      "ترتيب المواد اجتهادي من الجامع وليس من المؤلف"
    ],
    "historical_significance": "أضخم مجموعة لفتاوى عالم واحد في التراث الإسلامي، في 35 مجلداً، وهي المصدر الرئيسي لمعرفة آراء ابن تيمية في مختلف العلوم الشرعية",
    "muhaqiq_reputation": "عبد الرحمن بن محمد بن قاسم (ت 1392هـ) عالم نجدي جليل، أفنى عمره في جمع هذا المجموع من مخطوطات متفرقة حول العالم، وأكمل ابنه محمد العمل بعده",
    "tahqiq_methodology_note": "جمع وترتيب موضوعي للفتاوى والرسائل من مخطوطات متعددة، مع تخريج الأحاديث والآثار، وهذه طبعة مجمع الملك فهد 1425هـ",
