# KR Environment Configuration
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to git — only .env.template is committed.

# ── LLM API Keys (for multi-model consensus, D-041) ──
# At least TWO providers needed for true consensus independence.

# Option A: OpenRouter (recommended — single key accesses all models)
OPENROUTER_API_KEY=

# Option B: Direct provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── OCR (for PDF and image sources, D-028) ──
MISTRAL_API_KEY=

# ── Vector Search (for scholar interface semantic search) ──
# Qdrant runs locally by default. Only needed for Qdrant Cloud:
# QDRANT_URL=
# QDRANT_API_KEY=

# ── Application Configuration ──
KR_LIBRARY_PATH=./library
KR_LOG_LEVEL=INFO
KR_HUMAN_GATE_MODE=queue
KR_GUI_PORT=8000
