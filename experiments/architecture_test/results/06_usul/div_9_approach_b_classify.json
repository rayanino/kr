{
  "segments": [
    {
      "segment_index": 1,
      "start_word": 0,
      "end_word": 3,
      "text_snippet": "مسَائِل الْأَحْكَام الشَّرْعِيَّة",
      "scholarly_function": "structural_transition",
      "confidence": 0.85
    },
    {
      "segment_index": 2,
      "start_word": 4,
      "end_word": 9,
      "text_snippet": "وَقَالَ شُرَيْح أَنا أَقْْضِي وَلَا أُفْتِي",
      "scholarly_function": "narration",
      "confidence": 0.9
    },
    {
      "segment_index": 3,
      "start_word": 10,
      "end_word": 14,
      "text_snippet": "فصل فِي أَقسَام الْمُفْتِينَ",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 4,
      "start_word": 15,
      "end_word": 23,
      "text_snippet": "قَالَ أَبُو عَمْرو ابْن الصّلاح الْمفْتُون قِسْمَانِ مُسْتَقل وَغَيره",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 5,
      "start_word": 24,
      "end_word": 107,
      "text_snippet": "فالمستقل شرطُه مَعَ مَا ذكرنَا أَن يكون قيمًا بِمَعْرِِفَة أَدِلَّة",
      "scholarly_function": "definition",
      "confidence": 0.93
    },
    {
      "segment_index": 6,
      "start_word": 108,
      "end_word": 126,
      "text_snippet": "فَمن جمع هَذِه الْأَوْصَاف فَهُوَ الْمُفْتِي الْمُطلق المستقل",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 7,
      "start_word": 127,
      "end_word": 138,
      "text_snippet": "لِأَنَّهُ يسْتَقلّ بالأدلة بِغَيْر تَقْلِيد وتقيد بِمذهب أحد",
      "scholarly_function": "evidence_rational",
      "confidence": 0.85
    },
    {
      "segment_index": 8,
      "start_word": 139,
      "end_word": 170,
      "text_snippet": "قَالَ أَبُو عَمْرو وَمَا شرطناه من حفظه لمسائل الْفِقْه لم يشْتَرط",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 9,
      "start_word": 171,
      "end_word": 183,
      "text_snippet": "لِأَن الْفِقْه ثَمَرَته فَيتَأَخَّر عَنهُ وَشرط الشَّيْء لَا يتَأَخَّر",
      "scholarly_function": "evidence_rational",
      "confidence": 0.9
    },
    {
      "segment_index": 10,
      "start_word": 184,
      "end_word": 210,
      "text_snippet": "وشَرَطَه الْأُسْتَاذ أَبُو إِسْحَاق الإِسْفِرَايِينِيّ وَصَاحبه أَبُو مَنْصُور",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 11,
      "start_word": 211,
      "end_word": 230,
      "text_snippet": "ثمَّ لَا يشْتَرط أَن تكون جَمِيع الْأَحْكَام على ذهنه بل يَكْفِيهِ",
      "scholarly_function": "condition_exception",
      "confidence": 0.9
    },
    {
      "segment_index": 12,
      "start_word": 231,
      "end_word": 243,
      "text_snippet": "وَهل يشْتَرط أَن يعرف من الْحساب مَا يصحح بِهِ الْمسَائِل",
      "scholarly_function": "rule_statement",
      "confidence": 0.8
    },
    {
      "segment_index": 13,
      "start_word": 244,
      "end_word": 256,
      "text_snippet": "حكى أَبُو إِسْحَاق وَأَبُو مَنْصُور فِيهِ خلافًا لِأَصْحَابِنَا وَالأَصَح",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 14,
      "start_word": 257,
      "end_word": 290,
      "text_snippet": "ثمَّ إِنَّمَا يشْتَرط اجْتِمَاع الْعُلُوم الْمَذْكُورَة فِي مُفتٍ مُطلق",
      "scholarly_function": "condition_exception",
      "confidence": 0.92
    },
    {
      "segment_index": 15,
      "start_word": 291,
      "end_word": 310,
      "text_snippet": "وَمِنْهُم من مَنعه مُطلقًا وَأَجَازَهُ ابْن الصّباغ فِي الْفَرَائِض",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 16,
      "start_word": 311,
      "end_word": 332,
      "text_snippet": "الْقسم الثَّانِي الْمُفْتِي الَّذِي لَيْسَ بمستقل وَمندهر طَوِيل عُدِم",
      "scholarly_function": "structural_transition",
      "confidence": 0.88
    },
    {
      "segment_index": 17,
      "start_word": 333,
      "end_word": 340,
      "text_snippet": "وللمفتي المنتسب أَرْبَعَة أَحْوَال",
      "scholarly_function": "definition",
      "confidence": 0.85
    },
    {
      "segment_index": 18,
      "start_word": 341,
      "end_word": 363,
      "text_snippet": "أَحدهَا أَن لَا يكون مُقَلدًا لإمامه لَا فِي الْمَذْهَب وَلَا فِي",
      "scholarly_function": "definition",
      "confidence": 0.9
    },
    {
      "segment_index": 19,
      "start_word": 364,
      "end_word": 410,
      "text_snippet": "وَادّعى الْأُسْتَاذ أَبُو إِسْحَاق الأسفراييني هَذِه الصّفة لِأَصْحَابِنَا",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 20,
      "start_word": 411,
      "end_word": 443,
      "text_snippet": "ثمَّ قَالَ وَالصَّحِيح الَّذِي ذهب إِلَيْهِ الْمُحَقِّقُونَ مَا ذهب إِلَيْهِ",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 21,
      "start_word": 444,
      "end_word": 470,
      "text_snippet": "وَذكر أَبُو عَليّ السنجي بِكَسْر السِّين الْمُهْملَة نَحْو هَذَا فَقَالَ",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 22,
      "start_word": 471,
      "end_word": 497,
      "text_snippet": "قلتُ هَذَا الَّذِي ذكرَاهُ مُوَافق لما أَمرهم بِهِ الشَّافِعِي ثمَّ الْمُزنِيّ",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 23,
      "start_word": 498,
      "end_word": 527,
      "text_snippet": "قَالَ أَبُو عَمرو دَعْوَى انْتِفَاء التَّقْلِيد عَنْهُم مُطلقًا لَا يَسْتَقِيم",
      "scholarly_function": "refutation",
      "confidence": 0.92
    },
    {
      "segment_index": 24,
      "start_word": 528,
      "end_word": 542,
      "text_snippet": "وحَكَى بعض أَصْحَاب الْأُصُول مِنَّا أَنه لم يُوجد بعد عصر الشَّافِعِي",
      "scholarly_function": "opinion_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 25,
      "start_word": 543,
      "end_word": 558,
      "text_snippet": "ثمَّ فَتْوَى الْمُفْتِي فِي هَذِه الْحَالة كفتوى المستقل فِي الْعَمَل",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 26,
      "start_word": 559,
      "end_word": 583,
      "text_snippet": "الْحَالة الثَّانِيَة أَن يكون مُجْتَهدا مقيَّداً فِي مَذْهَب إِمَامه",
      "scholarly_function": "definition",
      "confidence": 0.92
    },
    {
      "segment_index": 27,
      "start_word": 584,
      "end_word": 627,
      "text_snippet": "وَشَرطه كَونه عَالما بالفقه وأصوله وأدلة الْأَحْكَام تَفْصِيلًا بَصيرًا",
      "scholarly_function": "definition",
      "confidence": 0.9
    },
    {
      "segment_index": 28,
      "start_word": 628,
      "end_word": 668,
      "text_snippet": "وَلَا يعرى عَن شوب تَقْلِيد لَهُ لإخلاله بِبَعْض أدوات المستقل",
      "scholarly_function": "condition_exception",
      "confidence": 0.88
    },
    {
      "segment_index": 29,
      "start_word": 669,
      "end_word": 690,
      "text_snippet": "وَهَذِه صفة أَصْحَابنَا أَصْحَاب الْوُجُوه وَعَلَيْهَا كَانَ أَئِمَّة أَصْحَابنَا",
      "scholarly_function": "opinion_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 30,
      "start_word": 691,
      "end_word": 700,
      "text_snippet": "وَالْعَامِل بفتوى هَذَا مقلد لإمامه لَا لَهُ",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 31,
      "start_word": 701,
      "end_word": 714,
      "text_snippet": "ثمَّ ظَاهر كَلَام الْأَصْحَاب أنَّ من هَذَا حَاله لَا يتأدَّى بِهِ",
      "scholarly_function": "opinion_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 32,
      "start_word": 715,
      "end_word": 742,
      "text_snippet": "قَالَ أَبُو عَمْرو وَيظْهر تأدي الْفَرْض بِهِ فِي الْفَتْوَى وَإِن لم",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 33,
      "start_word": 743,
      "end_word": 755,
      "text_snippet": "لأنَّه قَامَ مقَام إِمَامه المستقل تَفْرِيعا على الصَّحِيح وَهُوَ جَوَاز",
      "scholarly_function": "evidence_rational",
      "confidence": 0.88
    },
    {
      "segment_index": 34,
      "start_word": 756,
      "end_word": 767,
      "text_snippet": "ثمَّ قد يسْتَقلّ الْمُقَيد فِي مَسْأَلَة أَو بَاب خَاص كَمَا تقدم",
      "scholarly_function": "condition_exception",
      "confidence": 0.85
    },
    {
      "segment_index": 35,
      "start_word": 768,
      "end_word": 793,
      "text_snippet": "وَله أَن يُفْتِي فِيمَا لَا نصَّ فِيهِ لإمامه بِمَا يُخرجهُ على أُصُوله",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 36,
      "start_word": 794,
      "end_word": 810,
      "text_snippet": "ثمَّ إِذا أفتى بتخريجه فالمستفتي مقلد لإمامه لَا لَهُ هَكَذَا قطع بِهِ",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 37,
      "start_word": 811,
      "end_word": 838,
      "text_snippet": "قَالَ الشَّيْخ أَبُو عَمْرو وَيَنْبَغِي أَن يخرج هَذَا على خلاف حَكَاهُ",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 38,
      "start_word": 839,
      "end_word": 848,
      "text_snippet": "وَالأَصَح أَنه لَا ينْسب إِلَيْهِ",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 39,
      "start_word": 849,
      "end_word": 876,
      "text_snippet": "ثمَّ تَارَة يخرِّج من نَص معِين لإمامه وَتارَة لَا يجده فيخرّج على",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 40,
      "start_word": 877,
      "end_word": 897,
      "text_snippet": "فَإِن نصَّ إِمَامه على شَيْء وَنَصّ فِي مَسْأَلَة تشبهها على خِلَافه",
      "scholarly_function": "definition",
      "confidence": 0.88
    },
    {
      "segment_index": 41,
      "start_word": 898,
      "end_word": 920,
      "text_snippet": "وَشرط هَذَا التَّخْرِيج أَن لَا يجد بَين نصيه فرقا فَإِن وجده وَجب",
      "scholarly_function": "condition_exception",
      "confidence": 0.92
    },
    {
      "segment_index": 42,
      "start_word": 921,
      "end_word": 935,
      "text_snippet": "ويختلفون كثيرا فِي القَوْل بالتخريج فِي مثل ذَلِك لاختلافهم فِي إِمْكَان",
      "scholarly_function": "opinion_statement",
      "confidence": 0.85
    },
    {
      "segment_index": 43,
      "start_word": 936,
      "end_word": 944,
      "text_snippet": "قلتُ وَأكْثر ذَلِك يُمكن فِيهِ الفرقُ وَقد ذَكرُوهُ",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 44,
      "start_word": 945,
      "end_word": 985,
      "text_snippet": "الْحَالة الثَّالِثَة أَن لَا يبلغ رُتْبَة أَصْحَاب الْوُجُوه لكنه فَقِيه",
      "scholarly_function": "definition",
      "confidence": 0.92
    },
    {
      "segment_index": 45,
      "start_word": 986,
      "end_word": 1020,
      "text_snippet": "وَهَذِه صفةُ كثيرٍمن الْمُتَأَخِّرين إِلَى أَوَاخِر المئة الرَّابِعَة المصنفين",
      "scholarly_function": "opinion_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 46,
      "start_word": 1021,
      "end_word": 1055,
      "text_snippet": "وَأما فتاويهم فَكَانُوا يتبسطون فِيهَا تبسط أُولَئِكَ أَو قَرِيبا مِنْهُ",
      "scholarly_function": "opinion_statement",
      "confidence": 0.85
    },
    {
      "segment_index": 47,
      "start_word": 1056,
      "end_word": 1088,
      "text_snippet": "الْحَالة الرَّابِعَة أَن يقوم بِحِفْظ الْمَذْهَب وَنَقله وفهمه فِي الواضحات",
      "scholarly_function": "definition",
      "confidence": 0.92
    },
    {
      "segment_index": 48,
      "start_word": 1089,
      "end_word": 1113,
      "text_snippet": "فَهَذَا يعْتَمد نَقله وفتواه بِهِ فِيمَا يحكيه من مسطورات مذْهبه من",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 49,
      "start_word": 1114,
      "end_word": 1145,
      "text_snippet": "وَمَا لَا يجده مَنْقُولًا إِن وجد فِي الْمَنْقُول مَعْنَاهُ بِحَيْثُ يدْرك",
      "scholarly_function": "condition_exception",
      "confidence": 0.9
    }
  ],
  "total_segments": 49
}