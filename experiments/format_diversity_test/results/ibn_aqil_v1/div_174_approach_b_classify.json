{
  "segments": [
    {
      "segment_index": 1,
      "start_word": 0,
      "end_word": 3,
      "text_snippet": "المعرف بأداة التعريف",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 2,
      "start_word": 4,
      "end_word": 18,
      "text_snippet": "أل حرف تعريف أو اللام فقط … فنمط عرفت قل فيه النمط",
      "scholarly_function": "rule_statement",
      "confidence": 0.85
    },
    {
      "segment_index": 3,
      "start_word": 19,
      "end_word": 60,
      "text_snippet": "اختلف النحويون في حرف التعريف في الرجل ونحوه فقال الخل",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 4,
      "start_word": 61,
      "end_word": 82,
      "text_snippet": "والألف واللام المعرفة تكون للعهد كقولك لقيت رجلا فأكرمت",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 5,
      "start_word": 83,
      "end_word": 95,
      "text_snippet": "وقوله تعالى: {كَمَا أَرْسَلْنَا إِلَى فِرْعَوْنَ رَسُولاً فَعَصَى فِرْعَوْنُ الرَّسُولَ}",
      "scholarly_function": "evidence_quran",
      "confidence": 0.97
    },
    {
      "segment_index": 6,
      "start_word": 96,
      "end_word": 115,
      "text_snippet": "ولاستغراق الجنس نحو إن الإنسان لفي خسر وعلامتها أن يصل",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 7,
      "start_word": 116,
      "end_word": 131,
      "text_snippet": "ولتعريف الحقيقة نحو الرجل خير من المرأة أي هذه الحقيقة",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 8,
      "start_word": 132,
      "end_word": 158,
      "text_snippet": "والنمط ضرب من البسط والجمع أنماط مثل سبب وأسباب والنمط",
      "scholarly_function": "definition",
      "confidence": 0.93
    },
    {
      "segment_index": 9,
      "start_word": 159,
      "end_word": 175,
      "text_snippet": "وقد تزاد لازما: كاللات … والآن والذين ثم اللات",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 10,
      "start_word": 176,
      "end_word": 194,
      "text_snippet": "ولاضطرار: كبنات الأوبر … كذا وطبت النفس يا قيس السري",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 11,
      "start_word": 195,
      "end_word": 222,
      "text_snippet": "ذكر المصنف في هذين البيتين أن الألف واللام تأتي زائدة وه",
      "scholarly_function": "editorial_note",
      "confidence": 0.88
    },
    {
      "segment_index": 12,
      "start_word": 223,
      "end_word": 252,
      "text_snippet": "ثم مثل الزائدة اللازمة ب اللات وهو اسم صنم كان بمكة وب",
      "scholarly_function": "definition",
      "confidence": 0.85
    },
    {
      "segment_index": 13,
      "start_word": 253,
      "end_word": 306,
      "text_snippet": "واختلف في الألف واللام الداخلة عليه فذهب قوم إلى أنها لتع",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 14,
      "start_word": 307,
      "end_word": 360,
      "text_snippet": "ومثل أيضا ب الذين واللات والمراد بهما ما دخل عليه أل من",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 15,
      "start_word": 361,
      "end_word": 415,
      "text_snippet": "وأما حذفها في قراءة من قرأ صراط لذين أنعمت عليهم فلا يدل",
      "scholarly_function": "refutation",
      "confidence": 0.88
    },
    {
      "segment_index": 16,
      "start_word": 416,
      "end_word": 445,
      "text_snippet": "وأما الزائدة غير اللازمة فهي الداخلة اضطرارا على العلم كق",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 17,
      "start_word": 446,
      "end_word": 460,
      "text_snippet": "ومنه قوله: ولقد جنيتك أكمؤا وعساقلا … ولقد نهيتك عن بنا",
      "scholarly_function": "example",
      "confidence": 0.92
    },
    {
      "segment_index": 18,
      "start_word": 461,
      "end_word": 481,
      "text_snippet": "والأصل بنات أوبر فزيدت الألف واللام وزعم المبرد أن بنات",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 19,
      "start_word": 482,
      "end_word": 505,
      "text_snippet": "ومنه الداخلة اضطرارا على التمييز كقوله: رأيتك لما أن عرفت",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 20,
      "start_word": 506,
      "end_word": 540,
      "text_snippet": "والأصل وطبت نفسا فزاد الألف واللام وهذا بناء على أن التمي",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 21,
      "start_word": 541,
      "end_word": 565,
      "text_snippet": "وإلى هذين البيتين اللذين أنشدناهما أشار المصنف بقوله كبنا",
      "scholarly_function": "editorial_note",
      "confidence": 0.9
    },
    {
      "segment_index": 22,
      "start_word": 566,
      "end_word": 586,
      "text_snippet": "وبعض الأعلام عليه دخلا … للمح ما قد كان عنه نقلا كالفضل",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 23,
      "start_word": 587,
      "end_word": 620,
      "text_snippet": "ذكر المصنف فيما تقدم أن الألف واللام تكون معرفة وتكون زائ",
      "scholarly_function": "editorial_note",
      "confidence": 0.88
    },
    {
      "segment_index": 24,
      "start_word": 621,
      "end_word": 680,
      "text_snippet": "ثم ذكر في هذين البيتين أنها تكون للمح الصفة والمراد بها ال",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 25,
      "start_word": 681,
      "end_word": 720,
      "text_snippet": "وقد تدخل على المنقول من مصدر كقولك في فضل الفضل وعلى المن",
      "scholarly_function": "example",
      "confidence": 0.88
    },
    {
      "segment_index": 26,
      "start_word": 721,
      "end_word": 760,
      "text_snippet": "فيجوز دخول أل في هذه الثلاثة نظرا إلى الأصل وحذفها نظرا",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 27,
      "start_word": 761,
      "end_word": 810,
      "text_snippet": "وحاصله أنك إذا أردت بالمنقول من صفة ونحوه أنه إنما سمي به",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 28,
      "start_word": 811,
      "end_word": 855,
      "text_snippet": "كقولك الحارث نظرا إلى أنه إنما سمي به للتفاؤل وهو أنه يعي",
      "scholarly_function": "example",
      "confidence": 0.88
    },
    {
      "segment_index": 29,
      "start_word": 856,
      "end_word": 900,
      "text_snippet": "وإن لم تنظر إلى هذا ونظرت إلى كونه علما لم تدخل الألف وال",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 30,
      "start_word": 901,
      "end_word": 930,
      "text_snippet": "فدخول الألف واللام أفاد معنى لا يستفاد بدونهما فليستا بزائ",
      "scholarly_function": "refutation",
      "confidence": 0.85
    },
    {
      "segment_index": 31,
      "start_word": 931,
      "end_word": 970,
      "text_snippet": "وكذلك أيضا ليس حذفهما وإثباتهما على السواء كما هو ظاهر كل",
      "scholarly_function": "refutation",
      "confidence": 0.85
    },
    {
      "segment_index": 32,
      "start_word": 971,
      "end_word": 995,
      "text_snippet": "وقد يصير علما بالغلبه … مضاف أو مصحوب أل كالعقه وحذف أل",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 33,
      "start_word": 996,
      "end_word": 1040,
      "text_snippet": "من أقسام الألف واللام أنها تكون للغلبة نحو المدينة والكتاب",
      "scholarly_function": "definition",
      "confidence": 0.9
    },
    {
      "segment_index": 34,
      "start_word": 1041,
      "end_word": 1070,
      "text_snippet": "وحكم هذه الألف واللام أنها لا تحذف إلا في النداء أو الإضاف",
      "scholarly_function": "rule_statement",
      "confidence": 0.93
    },
    {
      "segment_index": 35,
      "start_word": 1071,
      "end_word": 1095,
      "text_snippet": "وقد تحذف في غيرهما شذوذا سمع من كلامهم هذا عيوق طالعا وال",
      "scholarly_function": "condition_exception",
      "confidence": 0.88
    },
    {
      "segment_index": 36,
      "start_word": 1096,
      "end_word": 1120,
      "text_snippet": "وقد يكون العلم بالغلبة أيضا مضافا كابن عمر وابن عباس وابن",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 37,
      "start_word": 1121,
      "end_word": 1165,
      "text_snippet": "فإنه غلب على العبادلة دون غيرهم من أولادهم وإن كان حقه الص",
      "scholarly_function": "example",
      "confidence": 0.88
    },
    {
      "segment_index": 38,
      "start_word": 1166,
      "end_word": 1190,
      "text_snippet": "وهذه الإضافة لا تفارقه لا في نداء ولا في غيره نحو يا ابن",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    }
