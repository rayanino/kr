    },
    {
      "segment_index": 53,
      "start_word": 1541,
      "end_word": 1562,
      "text_snippet": "نحو ممن أنت خير ومن أيهم أنت أفضل ومن غلام أيهم أنت أفضل",
      "scholarly_function": "example",
      "confidence": 0.95
    },
    {
      "segment_index": 54,
      "start_word": 1563,
      "end_word": 1583,
      "text_snippet": "وقد ورد التقديم شذوذا في غير الاستفهام وإليه أشار بقوله: ولدى إخبار التقديم",
      "scholarly_function": "condition_exception",
      "confidence": 0.85
    },
    {
      "segment_index": 55,
      "start_word": 1584,
      "end_word": 1607,
      "text_snippet": "ومن ذلك قوله: 282 - فقالت لنا أهلا وسهلا وزودت … جنى النحل بل ما",
