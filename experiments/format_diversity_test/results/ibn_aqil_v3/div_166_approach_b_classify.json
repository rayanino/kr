      "start_word": 0,
      "end_word": 1,
      "text_snippet": "أفعل التفضيل",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 2,
      "start_word": 2,
      "end_word": 13,
      "text_snippet": "صغ من مصوغ منه للتعجب … أفعل للتفضيل وأب اللذ أبى",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 3,
      "start_word": 14,
      "end_word": 47,
      "text_snippet": "يصاغ من الأفعال التي يجوز التعجب منها للدلالة على التفضيل وصف على وزن",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 4,
      "start_word": 48,
      "end_word": 62,
      "text_snippet": "فتقول زيد أفضل من عمرو وأكرم من خالد كما تقول ما أفضل",
      "scholarly_function": "example",
      "confidence": 0.95
    },
    {
      "segment_index": 5,
      "start_word": 63,
      "end_word": 107,
      "text_snippet": "وما امتنع بناء فعل التعجب منه امتنع بناء أفعل التفضيل منه فلا يبنى من فعل",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 6,
      "start_word": 108,
      "end_word": 163,
      "text_snippet": "كنعم وبئس ولا من فعللا يقبل المفاضلة كمات وفنى ولا من فعل ناقص ككان",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 7,
      "start_word": 164,
      "end_word": 207,
      "text_snippet": "وشذ منه قولهم هو أخصر من كذا فبنوا أفعل التفضيل من اختصر وهو زائد على",
      "scholarly_function": "condition_exception",
      "confidence": 0.9
    },
    {
      "segment_index": 8,
      "start_word": 208,
      "end_word": 222,
      "text_snippet": "وما به إلى تعجب وصل … لمانع به إلى التفضيل صل",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 9,
      "start_word": 223,
      "end_word": 262,
      "text_snippet": "تقدم في باب التعجب أنه يتوصل إلى التعجب من الأفعال التي لم تستكمل الشروط",
      "scholarly_function": "cross_reference",
      "confidence": 0.85
    },
    {
      "segment_index": 10,
      "start_word": 263,
      "end_word": 290,
      "text_snippet": "وأشار هنا إلى أنه يتوصل إلى التفضيل من الأفعال التي لم تستكمل الشروط بما",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 11,
      "start_word": 291,
      "end_word": 327,
      "text_snippet": "فكما تقول ما أشد استخراجه تقول هو أشد استخراجا من زيد وكما تقول ما أشد حمرته",
      "scholarly_function": "example",
      "confidence": 0.95
    },
    {
      "segment_index": 12,
      "start_word": 328,
      "end_word": 349,
      "text_snippet": "لكن المصدر ينتصب في باب التعجب بعد أشد مفعولا وههنا ينتصب تمييزا",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 13,
      "start_word": 350,
      "end_word": 363,
      "text_snippet": "وأفعل التفضيل صله أبدا … تقديرا أو لفظا بمن إن جردا",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 14,
      "start_word": 364,
      "end_word": 378,
      "text_snippet": "لا يخلو أفعل التفضيل عن أحد ثلاثة أحوال: الأول: أن يكون مجردا الثاني:",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 15,
      "start_word": 379,
      "end_word": 413,
      "text_snippet": "فإن كان مجردا فلا بد أن يتصل به من لفظا أو تقديرا جارة للمفضل نحو زيد",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 16,
      "start_word": 414,
      "end_word": 437,
      "text_snippet": "وقد تحذف من ومجرورها للدلالة عليهما كقوله تعالى: {أَنَا أَكْثَرُ مِنْكَ",
      "scholarly_function": "evidence_quran",
      "confidence": 0.95
    },
    {
      "segment_index": 17,
      "start_word": 438,
      "end_word": 472,
      "text_snippet": "وفهم من كلامه أن أفعل التفضيل إذا كان بأل أو مضافا لا تصحبه من فلا تقول",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 18,
      "start_word": 473,
      "end_word": 498,
      "text_snippet": "وأكثر ما يكون ذلك إذا كان أفعل التفضيل خبرا كالآية الكريمة ونحوها وهو كثير",
      "scholarly_function": "rule_statement",
      "confidence": 0.85
    },
    {
      "segment_index": 19,
      "start_word": 499,
      "end_word": 530,
      "text_snippet": "وقد تحذف منه وهو غير خبر كقوله: 279 - دنوت وقد خلناك كالبدر أجملا … فظل فؤادي",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 20,
      "start_word": 531,
      "end_word": 567,
      "text_snippet": "فـ \"أجمل\" أفعل تفضيل وهو منصوب على الحال من التاء في دنوت وحذفت منه من",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 21,
      "start_word": 568,
      "end_word": 588,
      "text_snippet": "ويلزم أفعل التفضيل المجرد الإفراد والتذكير وكذلك المضاف إلى نكرة وإلى هذا",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 22,
      "start_word": 589,
      "end_word": 601,
      "text_snippet": "وإن لمنكور يضف أو جردا … ألزم تذكيرا وأن يوحدا",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 23,
      "start_word": 602,
      "end_word": 672,
      "text_snippet": "فتقول زيد أفضل من عمرو وأفضل رجل وهند أفضل من عمرو وأفضل امرأة والزيدان",
      "scholarly_function": "example",
      "confidence": 0.95
    },
    {
      "segment_index": 24,
      "start_word": 673,
      "end_word": 694,
      "text_snippet": "فيكون أفعل في هاتين الحالتين مذكرا ومفردا ولا يؤنث ولا يثنى ولا يجمع",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 25,
      "start_word": 695,
      "end_word": 720,
      "text_snippet": "وتلو أل طبق وما لمعرفه … أضيف ذو وجهين عن ذي معرفههذا إذا نويت معنى من وإن",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 26,
      "start_word": 721,
      "end_word": 770,
      "text_snippet": "إذا كان أفعل التفضيل ب أل لزمت مطابقته لما قبله في الإفراد والتذكير وغيرهما",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 27,
      "start_word": 771,
      "end_word": 808,
      "text_snippet": "فتقول زيد الأفضل والزيدان الأفضلان والزيدون الأفضلون وهند الفضلى والهندان",
      "scholarly_function": "example",
      "confidence": 0.95
    },
    {
      "segment_index": 28,
      "start_word": 809,
      "end_word": 843,
      "text_snippet": "ولا يجوز عدم مطابقته لما قبله فلا تقول الزيدون الأفضل ولا الزيدان الأفضل",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 29,
      "start_word": 844,
      "end_word": 862,
      "text_snippet": "ولا يجوز أن تقترن به من فلا تقول زيد الأفضل من عمرو",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 30,
      "start_word": 863,
