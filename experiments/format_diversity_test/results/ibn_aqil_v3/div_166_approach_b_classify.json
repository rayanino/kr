      "confidence": 0.9
    },
    {
      "segment_index": 56,
      "start_word": 1608,
      "end_word": 1621,
      "text_snippet": "والتقدير بل ما زودت أطيب منه",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 57,
      "start_word": 1622,
      "end_word": 1651,
      "text_snippet": "وقول ذي الرمة يصف نسوة بالسمن والكسل: 285 - ولا عيب فيها غير أن سريعها",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 58,
      "start_word": 1652,
      "end_word": 1664,
      "text_snippet": "التقدير وأن لا شيء أكسل منهن وقوله:",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 59,
      "start_word": 1665,
      "end_word": 1688,
      "text_snippet": "284 - إذا سايرت أسماء يوما ظعينة … فأسماء من تلك الظعينة أملح التقدير فأسماء",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 60,
      "start_word": 1689,
      "end_word": 1710,
      "text_snippet": "ورفعه الظاهر نزر ومتى … عاقب فعلا فكثيرا ثبتا كلن ترى في الناس من رفيق",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 61,
      "start_word": 1711,
      "end_word": 1733,
      "text_snippet": "لا يخلو أفعل التفضيل من أن يصلح لوقوع فعل بمعناه موقعه أولا",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 62,
      "start_word": 1734,
      "end_word": 1758,
      "text_snippet": "فإن لم يصلح لوقوع فعل بمعناه موقعه لم يرفع ظاهرا وإنما يرفع ضميرا مستترا",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 63,
      "start_word": 1759,
      "end_word": 1786,
      "text_snippet": "فلا تقول مررت برجل أفضل منه أبوه فترفع أبوه ب أفضل إلا في لغة ضعيفة حكاها",
      "scholarly_function": "condition_exception",
