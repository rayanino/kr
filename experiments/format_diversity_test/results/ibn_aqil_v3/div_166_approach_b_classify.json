    },
    {
      "segment_index": 64,
      "start_word": 1787,
      "end_word": 1826,
      "text_snippet": "فإن صلح لوقوع فعل بمعناه موقعه صح أن يرفع ظاهرا قياسا مطردا وذلك في كل موضع",
      "scholarly_function": "rule_statement",
      "confidence": 0.95
    },
    {
      "segment_index": 65,
      "start_word": 1827,
      "end_word": 1862,
      "text_snippet": "نحو ما رأيت رجلا أحسن في عينه الكحل منه في عين زيد ف الكحل مرفوع ب أحسن",
      "scholarly_function": "example",
      "confidence": 0.95
    },
    {
      "segment_index": 66,
      "start_word": 1863,
      "end_word": 1893,
      "text_snippet": "ومثله قوله صلى الله عليه وسلم ما من أيام أحب إلى الله فيها الصوم منه في عشر",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 67,
      "start_word": 1894,
      "end_word": 1926,
      "text_snippet": "وقول الشاعر أنشده سيبويه: 285 - مررت على وادي السباع ولا أرى … كوادي السباع",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 68,
