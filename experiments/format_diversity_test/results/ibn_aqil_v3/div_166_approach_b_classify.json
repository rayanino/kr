      "confidence": 0.85
    },
    {
      "segment_index": 36,
      "start_word": 1059,
      "end_word": 1082,
      "text_snippet": "وقد ورد الاستعمالان في القرآن فمن استعماله غير مطابق قوله تعالى: {وَلَتَجِدَنَّهُمْ",
      "scholarly_function": "evidence_quran",
      "confidence": 0.95
    },
    {
      "segment_index": 37,
      "start_word": 1083,
      "end_word": 1100,
      "text_snippet": "ومن استعماله مطابقا قوله تعالى: {وَكَذَلِكَ جَعَلْنَا فِي كُلِّ قَرْيَةٍ أَكَابِرَ",
      "scholarly_function": "evidence_quran",
      "confidence": 0.95
    },
    {
      "segment_index": 38,
      "start_word": 1101,
      "end_word": 1133,
      "text_snippet": "وقد اجتمع الاستعمالان في قوله صلى الله عليه وسلم: \" ألا أخبركم بأحبكم إلي",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 39,
      "start_word": 1134,
      "end_word": 1163,
      "text_snippet": "والذين أجازوا الوجهين قالوا الأفصح المطابقة ولهذا عيب على صاحب الفصيح في",
      "scholarly_function": "opinion_statement",
