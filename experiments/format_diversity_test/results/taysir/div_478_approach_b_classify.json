{
  "segments": [
    {
      "segment_index": 0,
      "start_word": 0,
      "end_word": 2,
      "text_snippet": "بَابُ الرِّبا والصَّرْف",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 1,
      "start_word": 3,
      "end_word": 20,
      "text_snippet": "الربا في اللغة: الزيادة، ومنه قوله تعالى: {فإذا أنزلنَا عَلْيَها المَاءَ اهتزت وَرَبَتْ} يعنى زادت.",
      "scholarly_function": "definition",
      "confidence": 0.95
    },
    {
      "segment_index": 2,
      "start_word": 21,
      "end_word": 30,
      "text_snippet": "وفى الشرع: الزيادة في أشياء مخصوصة.",
      "scholarly_function": "definition",
      "confidence": 0.95
    },
    {
      "segment_index": 3,
      "start_word": 31,
      "end_word": 40,
      "text_snippet": "وهو محرم بالكتاب، والسنة، والإجماع، والقياس الصحيح.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 4,
      "start_word": 41,
      "end_word": 50,
      "text_snippet": "فأما الكتاب فمثل قوله تعالى {وَحرّمَ الربا}",
      "scholarly_function": "evidence_quran",
      "confidence": 0.95
    },
    {
      "segment_index": 5,
      "start_word": 51,
      "end_word": 72,
      "text_snippet": "والسنة، في مثل الحديث، الذي لعن به صلى الله عليه وسلم [آكل الربا وموكله، وشاهده، وكاتبه] وهو متفق عليه.",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 6,
      "start_word": 73,
      "end_word": 88,
      "text_snippet": "وقد أجمعت الأمة على تحريم الربا في الجملة لما استندت عليه من النصوص.",
      "scholarly_function": "evidence_ijma",
      "confidence": 0.95
    },
    {
      "segment_index": 7,
      "start_word": 89,
      "end_word": 115,
      "text_snippet": "وتحريمه: - مقتضى العدل والقياس، لأن التعامل به ظلم أو ذريعة إليه. والكون لا يقوم إلا بالعدل",
      "scholarly_function": "evidence_rational",
      "confidence": 0.9
    },
    {
      "segment_index": 8,
      "start_word": 116,
      "end_word": 175,
      "text_snippet": "منها: - تضخم المال بطريق غير مشروعة، لأنه تضخم على حساب سلب مال الفقير وضمه إلى كنوز الَغنى",
      "scholarly_function": "evidence_rational",
      "confidence": 0.88
    },
    {
      "segment_index": 9,
      "start_word": 176,
      "end_word": 200,
      "text_snippet": "وهذا مصداق للحديث النبوي الشريف \"يأتي على الناس زمان يشربون الخمر ويسمونها بغير اسمها\".",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.9
    },
    {
      "segment_index": 10,
      "start_word": 201,
      "end_word": 210,
      "text_snippet": "وبسط هذه البحوث والرد عليها، له كتب غير هذا.",
      "scholarly_function": "cross_reference",
      "confidence": 0.9
    },
    {
      "segment_index": 11,
      "start_word": 211,
      "end_word": 222,
      "text_snippet": "أما الصرف: فمادته تدور على التقلب والتغير في الأشياء.",
      "scholarly_function": "definition",
      "confidence": 0.92
    },
    {
      "segment_index": 12,
      "start_word": 223,
      "end_word": 248,
      "text_snippet": "قال في اللسان: \"الصرف بيع الذهب بالفضة وبالعكس، أنه يتصرف به عن جوهر إلى جوهر\" فهو بيع الأثمان بعضها ببعض.",
      "scholarly_function": "definition",
      "confidence": 0.93
    },
    {
      "segment_index": 13,
      "start_word": 249,
      "end_word": 251,
      "text_snippet": "الحديث الأول",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 14,
      "start_word": 252,
      "end_word": 300,
      "text_snippet": "عَنْ عُمَرَ بْنِ الْخطَابِ رَضىَ الله عَنْهُ قَالَ: قَالَ رَسُول الله صلى الله عليه وسلم: \" الذًهَبُ بالذًهَبِ رِباً، إلا هَاءَ وَهَاءَ",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.98
    },
    {
      "segment_index": 15,
      "start_word": 301,
      "end_word": 302,
      "text_snippet": "الغريب:",
      "scholarly_function": "structural_transition",
      "confidence": 0.85
    },
    {
      "segment_index": 16,
      "start_word": 303,
      "end_word": 320,
      "text_snippet": "إلا هاء وهاء: فيهما لغات، أشهرها المد وفتح الهمزة فيهما، ومعناه التقابض.",
      "scholarly_function": "definition",
      "confidence": 0.9
    },
    {
      "segment_index": 17,
      "start_word": 321,
      "end_word": 323,
      "text_snippet": "المعنى الإجمالي:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 18,
      "start_word": 324,
      "end_word": 385,
      "text_snippet": "يبين النبي صلى الله عليه وسلم في هذا الحديث، كيفية البيع الصحيح بين هذه الأنواع",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 19,
      "start_word": 386,
      "end_word": 420,
      "text_snippet": "كما أن من باع- برا بِبُر، أو شعيرا بشعير، فلابد من التقابض بينهما",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 20,
      "start_word": 421,
      "end_word": 426,
      "text_snippet": "ما يستفاد من الحديث:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 21,
      "start_word": 427,
      "end_word": 452,
      "text_snippet": "1- تحريم بيع الذهب بالفضة أو العكس، وفساده إذا لم يتقابض المتبايعان قبل التفرق من مجلس العقد، وهذه هي المصارفة.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 22,
      "start_word": 453,
      "end_word": 475,
      "text_snippet": "2- تحريم بيع البر بالبر، أو الشعير بالشعير. وفساده، إذا لم يتقابض المتبايعان",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 23,
      "start_word": 476,
      "end_word": 500,
      "text_snippet": "3- صحة العقد إذا حصل القبض في المصارفة. أو بيع البر بالبر، أو الشعير بالشعير، في مجلس العقد.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 24,
      "start_word": 501,
      "end_word": 530,
      "text_snippet": "4- يراد بمجلس العقد مكان التبايع، سواء أكانا جالسين، أم ماضيين، أم راكبين. ويراد بالتفرق ما يُعَد تفرقا عرفا",
      "scholarly_function": "definition",
      "confidence": 0.9
    },
    {
      "segment_index": 25,
      "start_word": 531,
      "end_word": 533,
      "text_snippet": "الحديث الثاني",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 26,
      "start_word": 534,
      "end_word": 590,
      "text_snippet": "عَنْ أبي سَعيد الخُدرِىّ رضي الله عنه: أنَ رَسولَ الله صلى الله عليه وسلم قَالَ: \" لا تَبِيعُوا الذهَبَ بالذهَبِ، إلا مِثْلا بمثل",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.98
    },
    {
      "segment_index": 27,
      "start_word": 591,
      "end_word": 612,
      "text_snippet": "وفى لفظ: \" إلا يَداً بيدٍ \". وفي لفظ: \" إلا وَزْناً بِوَزْنٍ مِثلا بِمثْلى سَواءً بِسَواء\".",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.92
    },
    {
      "segment_index": 28,
      "start_word": 613,
      "end_word": 614,
      "text_snippet": "الغريب:",
      "scholarly_function": "structural_transition",
      "confidence": 0.85
    },
    {
      "segment_index": 29,
      "start_word": 615,
      "end_word": 626,
      "text_snippet": "1- الورق: هو الفضة مضروبة أو غير مضروبة.",
      "scholarly_function": "definition",
      "confidence": 0.95
    },
    {
      "segment_index": 30,
      "start_word": 627,
      "end_word": 665,
      "text_snippet": "2- ولا تُشفُّوا بعضها على بعض: بضم أوله، وكسر الشين المعجمة، وتشديد الفاء. أي لا تفضلوا بعضها على بعض.",
      "scholarly_function": "definition",
      "confidence": 0.93
    },
    {
      "segment_index": 31,
      "start_word": 666,
      "end_word": 668,
      "text_snippet": "المعنى الإجمالي:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 32,
      "start_word": 669,
      "end_word": 690,
      "text_snippet": "في هذا الحديث الشريف ينهى النبي صلى الله عليه وسلم عن الربا بنوعيه: الفضل، والنسيئة.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 33,
      "start_word": 691,
      "end_word": 730,
      "text_snippet": "فهو ينهى عن بيع الذهب بالذهب، سواء أكانا مضروبين، أم غير مضروبين، إلا إذا تماثلا وزناً بوزنْ",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 34,
      "start_word": 731,
      "end_word": 760,
      "text_snippet": "كما نهى عن بيع الفضة بالفضة، سواء أكانت مضروبة أم غير مضروبة، إلا أن تكون متماثلة وزناً بوزن",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 35,
      "start_word": 761,
      "end_word": 775,
      "text_snippet": "فلا يجوز زيادة أحدهما عن الآخر، ولا التفرُّق قبل التقابض.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 36,
      "start_word": 776,
      "end_word": 781,
      "text_snippet": "ما يستفاد من الحديث:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 37,
      "start_word": 782,
      "end_word": 820,
      "text_snippet": "1- النهى عن بيع الذهب بالذهب، أو الفضة بالفضة، سواء أكانت مضروبة، أم غير مضروبة، أم مختلفة",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 38,
      "start_word": 821,
      "end_word": 832,
      "text_snippet": "2- النهى عن ذلك يقتضي تحريمه وفساد العقد.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 39,
      "start_word": 833,
      "end_word": 855,
      "text_snippet": "3- التماثل والتقابض بمجلس العقد، مشروط بين جميع الأموال الربوية، ويأتي بيان ما يجمعها إن شاء الله.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 40,
      "start_word": 856,
      "end_word": 930,
      "text_snippet": "4- قال شيخ الإسلام ابن تيمية في رجل يداين الناس كل مائة بمائة وأربعين ويجعل سلفا على حرير: هذا هو عين الربا",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 41,
      "start_word": 931,
      "end_word": 950,
      "text_snippet": "أما ما قبضه بتأول فيعفى عنه: وأما ما بقى في الذمم فهو ساقط لقوله تعالى: {وذروا ما بقى من الربا}",
      "scholarly_function": "evidence_quran",
      "confidence": 0.85
    },
    {
      "segment_index": 42,
      "start_word": 951,
      "end_word": 953,
      "text_snippet": "اختلاف العلماء:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 43,
      "start_word": 954,
      "end_word": 1010,
      "text_snippet": "أجمع العلماء على تحريم التفاضل والنساء في جنس واحد من الأجناس، التي نص عليها حديث عبادة بن الصامت",
      "scholarly_function": "evidence_ijma",
      "confidence": 0.9
    },
    {
      "segment_index": 44,
      "start_word": 1011,
      "end_word": 1055,
      "text_snippet": "قال: \" سمعت رسول الله صلى الله عليه وسلم ينهى عن بيع الذهب بالذهب، والفضة بالفضة، والبر بالبر",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.98
    },
    {
      "segment_index": 45,
      "start_word": 1056,
      "end_word": 1070,
      "text_snippet": "فهو نص في منع التفاضل في الجنس الواحد من هذه الأعيان المذكورة.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 46,
      "start_word": 1071,
      "end_word": 1120,
      "text_snippet": "وأما منع النسيئة، فيستفاد من مثل حديث عمر بن الخطاب قال: قال رسول اللَه صلى الله عليه وسلم: \" الذهب بالذهب رباً، إلا هاء وهاء",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 47,
      "start_word": 1121,
      "end_word": 1155,
      "text_snippet": "ويجوز بيع الجنس الواحد من هذه الستة بالجنس الآخر نَساء لبقية حديث عبادة",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 48,
      "start_word": 1156,
      "end_word": 1190,
      "text_snippet": "وكل هذا مجمع عليه عند العلماء، إلا في الشعير مع البر، فقد رأى بعضهم أنَهما جنس واحد، والصحيح أنهما جنسان.",
      "scholarly_function": "evidence_ijma",
      "confidence": 0.85
    },
    {
      "segment_index": 49,
      "start_word": 1191,
      "end_word": 1207,
      "text_snippet": "وقد ذهبت الظاهرية إلى أن الربا لا يتعدى هذه الأجناس الستة لنفيهمُ القياس.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 50,
      "start_word": 1208,
      "end_word": 1235,
      "text_snippet": "وأما جمهور العلماء فقد عَدّوا الحكم إلى غيرها من الأشياء. واختلفوا في الأشياء الملحقة، تبعاً لاختلافهم في فهم العلة",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 51,
      "start_word": 1236,
      "end_word": 1260,
      "text_snippet": "وقد اتفق العلماء على أن العلة في الذهب والفضة، غير العلة في الأربعة الباقية وأن لكل منهما علة واحدة.",
      "scholarly_function": "evidence_ijma",
      "confidence": 0.85
    },
    {
      "segment_index": 52,
      "start_word": 1261,
      "end_word": 1265,
      "text_snippet": "ثم اختلفوا في العلة.",
      "scholarly_function": "structural_transition",
      "confidence": 0.85
    },
    {
      "segment_index": 53,
      "start_word": 1266,
      "end_word": 1295,
      "text_snippet": "فالرواية المشهورة عن الإمام أحمد، في الذهب والفضة كونهما موزوني جنس وفى الأربعة الباقية، كونها مكيلة جنس",
      "scholarly_function": "opinion_statement",
      "confidence": 0.93
    },
    {
      "segment_index": 54,
      "start_word": 1296,
      "end_word": 1310,
      "text_snippet": "وبهذا القول قال النخعي، والزهري، والثوري، وإسحاق والحنفية.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 55,
      "start_word": 1311,
      "end_word": 1350,
      "text_snippet": "فعلى هذا يجرى الربَا في كل موزون، أو مكيل بيع بجنسه، سواء أكان مطعوماً، كالحبوب، والسكر",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 56,
      "start_word": 1351,
      "end_word": 1370,
      "text_snippet": "وغير المكيل أو الموزون لا يجرى فيه، وأن كان مطعوما، كالفواكه المعدودة.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 57,
      "start_word": 1371,
      "end_word": 1405,
      "text_snippet": "ويستدلون على ثبوت هذا التعليل عندهم، بما رواه أحمد عن ابن عمر: أن رسول الله صلى الله عليه وسلم قال: \" لا تبيعوا الدينار بالدينارين",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 58,
      "start_word": 1406,
      "end_word": 1440,
      "text_snippet": "وما رواه الدارقطنى عن أنس: أن النبي صلى الله عليه وسلم قال: \" ما وُزِنَ مثلا بمثل، نوعاً واحدا. وما كيل، فمثل ذلك",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 59,
      "start_word": 1441,
      "end_word": 1455,
      "text_snippet": "فاعتبر، هنا، الكيل، أو الوزن في الجنس الواحد، لتحقق العلة.",
      "scholarly_function": "evidence_rational",
      "confidence": 0.85
    },
    {
      "segment_index": 60,
      "start_word": 1456,
      "end_word": 1480,
      "text_snippet": "وذهب الشافعي إلى أن العلة، الطعم والجنس، والعلة في الذهب والفضة، كونهما ثمنين للأشياء، فيختص الحكم بهما.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.93
    },
    {
      "segment_index": 61,
      "start_word": 1481,
      "end_word": 1505,
      "text_snippet": "والدليل على ذلك، ما رواه مسلم، عن معمر بن عبد الله: أن النبي صلى الله عليه وسلم \" نهى عن بيع الطعام بالطعام، إلا مثلا بمثل\".",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 62,
      "start_word": 1506,
      "end_word": 1520,
      "text_snippet": "فقد علَّق الحكم باسم الطعام، فدل على العلة واشتقاقها.",
      "scholarly_function": "evidence_rational",
      "confidence": 0.88
    },
    {
      "segment_index": 63,
      "start_word": 1521,
      "end_word": 1550,
      "text_snippet": "ووافق الإمام مالك الشافعي في النقدين، أم غيرهما، فالعلة عنده فيه ترجع إلى الجنس والادخار، والاقتيات.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.93
    },
    {
      "segment_index": 64,
      "start_word": 1551,
      "end_word": 1575,
      "text_snippet": "وكذلك ما يصلح الطعام من التوابل. ويرون أن الأصناف الأربعة المذكورة في الحديث جاءت للتنبيه على ما في معناها",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 65,
      "start_word": 1576,
      "end_word": 1600,
      "text_snippet": "فالبر، والشعير، لأنواعْ الحبوب. والتمر لأنواع الحلويات، كالسكر والعسل، والملح، لأنواع التوابل.",
      "scholarly_function": "example",
      "confidence": 0.9
    },
    {
      "segment_index": 66,
      "start_word": 1601,
      "end_word": 1630,
      "text_snippet": "وهناك رواية أخرى عن الإمام أحمد هي مذهب الإمام الشافعي في القديم، وقال بها سعيد بن المسيب.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 67,
      "start_word": 1631,
      "end_word": 1660,
      "text_snippet": "وهى أن العلة في الأربعة المذكورة في الحديث: الطعم، والكيل أو الوزن فلا يجرى الربا في مطعوم لا يكال ولا يوزن",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 68,
      "start_word": 1661,
      "end_word": 1680,
      "text_snippet": "كما لا يجرى في مكيل أو موزون لا يطعم. فلابد من اعتبار الأمرين",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 69,
      "start_word": 1681,
      "end_word": 1720,
      "text_snippet": "لأن الكيل وحده، أو الوزن وحده، لا يقتضي وجوب المماثلة، كما أن الطعم وحده لا تتحقق به المماثلة",
      "scholarly_function": "evidence_rational",
      "confidence": 0.9
    },
    {
      "segment_index": 70,
      "start_word": 1721,
      "end_word": 1740,
      "text_snippet": "وبهذا القول تجتمع الأحاديث الواردة في هذه المسألة، ويقيد كل حديث منها بالآخر.",
      "scholarly_function": "evidence_rational",
      "confidence": 0.85
    },
    {
      "segment_index": 71,
      "start_word": 1741,
      "end_word": 1765,
      "text_snippet": "وقد اختار هذا القول [صاحب المغنى] والشارح عبد الرحمن بن أبي عمر، وشيخ الإسلام \" ابن تيمية\" رحمهم الله تعالى.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 72,
      "start_word": 1766,
      "end_word": 1767,
      "text_snippet": "تلخيص:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 73,
      "start_word": 1768,
      "end_word": 1800,
      "text_snippet": "قال في المغنى: فالحاصل إن ما اجتمع فيه الكيل والوزن والطعم من جنس واحد، ففيه الربا. رواية واحدة كالأرز",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 74,
      "start_word": 1801,
      "end_word": 1815,
      "text_snippet": "وهذا قول أكثر أهل العلم وعلماء الأمصار في القديم والحديث.",
      "scholarly_function": "evidence_ijma",
      "confidence": 0.8
    },
    {
      "segment_index": 75,
      "start_word": 1816,
      "end_word": 1845,
      "text_snippet": "وما يعدم فيه الكيل، والوزن والطعم، واختلف جنسه، فلا ربا فيه رواية واحدة. وهو قول أكثر العلماء، وذلك كالتين والنوى.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 76,
      "start_word": 1846,
      "end_word": 1870,
      "text_snippet": "وما وجد فيه الطعم وحده، أو الكيل والوزن من جنس واحد، فيه روايتان. واختلف أهل العلم فيه",
      "scholarly_function": "opinion_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 77,
      "start_word": 1871,
      "end_word": 1920,
      "text_snippet": "والأولى- إن شاء الله- حِله، إذ ليس في تحريمه دليل موثوق به، ولا معنى يقوى التمسك به",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 78,
      "start_word": 1921,
      "end_word": 1923,
      "text_snippet": "الحديث الثالث",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 79,
      "start_word": 1924,
      "end_word": 2010,
      "text_snippet": "عَن أبي سَعِيدٍ الخُدري رَضىَ الله عَنْهُ قَالَ: جَاءَ بلال إلى النَّبي صلى الله عليه وسلم بِتَمْر بَرْنى",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.98
    },
    {
      "segment_index": 80,
      "start_word": 2011,
      "end_word": 2012,
      "text_snippet": "الغريب:",
      "scholarly_function": "structural_transition",
      "confidence": 0.85
    },
    {
      "segment_index": 81,
      "start_word": 2013,
      "end_word": 2030,
      "text_snippet": "بَرْني: من تمر المدينة الجيد، وهو معروف بها إلى الآن، بسره أصفر، فيه طول.",
      "scholarly_function": "definition",
      "confidence": 0.92
    },
    {
      "segment_index": 82,
      "start_word": 2031,
      "end_word": 2042,
      "text_snippet": "أوه أوه: كلمة يؤتى بها للتوجع، أو التفجع.",
      "scholarly_function": "definition",
      "confidence": 0.92
    },
    {
      "segment_index": 83,
      "start_word": 2043,
      "end_word": 2045,
      "text_snippet": "المعنى الإجمالي:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 84,
      "start_word": 2046,
      "end_word": 2075,
      "text_snippet": "جاء بلال إلى النبي صلى الله عليه وسلم بتمر برني جيد، فتعجب النبي صلى الله عليه وسلم من جودته وقال: منأين هذا؟",
      "scholarly_function": "narration",
      "confidence": 0.85
    },
    {
      "segment_index": 85,
      "start_word": 2076,
      "end_word": 2105,
      "text_snippet": "قال بلال: كان عندنا تمر، فبعت الصاعين من الردي بصاع من هذا الجيد، ليكون مطعم النبي صلى الله عليه وسلم منه.",
      "scholarly_function": "narration",
      "confidence": 0.85
    },
    {
      "segment_index": 86,
      "start_word": 2106,
      "end_word": 2125,
      "text_snippet": "فعظم ذلك على النبي صلى الله عليه وسلم وتأوه، لأن المعصية عنده هي أعظم المصائب.",
      "scholarly_function": "narration",
      "confidence": 0.85
    },
    {
      "segment_index": 87,
      "start_word": 2126,
      "end_word": 2165,
      "text_snippet": "وقال: عملك هذا، هو عين الربا المحرم، فلا تفعل، ولكن إذا أردت استبدال رديء، فبع الرديء بدراهم",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 88,
      "start_word": 2166,
      "end_word": 2171,
      "text_snippet": "ما يستفاد من الحديث:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 89,
      "start_word": 2172,
      "end_word": 2195,
      "text_snippet": "1- تحريم ربا الفضل بالتمر، بأن يباع بعضه ببعض، وأحدهما أكثر من الأخر.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 90,
      "start_word": 2196,
      "end_word": 2240,
      "text_snippet": "2- استدل بالحديث على جواز [مسألة العينة] وهى أن يبيع سلعة نسيئة، ثم يشتريها من المشترى بنقد أقل من ثمنها الأول",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 91,
      "start_word": 2241,
      "end_word": 2285,
      "text_snippet": "3- استدل بالحديث على جواز [مسألة التورق] ، وهى أن يشترى ما يساوى مائة ريال، بمائة وعشرين مؤجلة",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 92,
      "start_word": 2286,
      "end_word": 2300,
      "text_snippet": "4- عظم المعصية، كيف بلغت من نفس النبي صلى الله عليه وسلم.",
      "scholarly_function": "rule_statement",
      "confidence": 0.8
    },
    {
      "segment_index": 93,
      "start_word": 2301,
      "end_word": 2325,
      "text_snippet": "5- لم يذكر في الحديث أن النبي صلى الله عليه وسلم أمره برد البيع. والسكوت عن الرد، لا يدل على عدمه.",
      "scholarly_function": "rule_statement",
      "confidence": 0.85
    },
    {
      "segment_index": 94,
      "start_word": 2326,
      "end_word": 2340,
      "text_snippet": "وقد ورد في بعض الطرق أنه قال: [هذا الربا فرِده]",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.9
    },
    {
      "segment_index": 95,
      "start_word": 2341,
      "end_word": 2360,
      "text_snippet": "وقد قال تعالى: {فإنْ تُبتم فَلَكُم رُؤوس أمْوَاِلكُم لا تَظْلِمُونَ وَلا تُظْلَمُون}",
      "scholarly_function": "evidence_quran",
      "confidence": 0.95
    },
    {
      "segment_index": 96,
      "start_word": 2361,
      "end_word": 2395,
      "text_snippet": "6- جواز الترفه في المأكل والمشرب، ما لم يصل إلى حد التبذير، والسرف المنهي عنه",
      "scholarly_function": "rule_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 97,
      "start_word": 2396,
      "end_word": 2420,
      "text_snippet": "فقد قال تعالى: {قُلْ مَنْ حَرمَ زِينَةَ الله التي أخْرَجَ لِعِبَادِهِ وَالطَيباتِ مِنَ الرِّزْقِ؟ قُلْ هي لِلَّذِينَ آمَنُوا في الحَيَاةِ الدُّنيا}",
      "scholarly_function": "evidence_quran",
      "confidence": 0.95
    },
    {
      "segment_index": 98,
      "start_word": 2421,
      "end_word": 2445,
      "text_snippet": "7- فيه بيان شيء من أدب المفتى. وهو أنه إذا سئل عن مسألة محرمة، ونهى عنها المستفتى، أن يفتح أمامه أبواب الطرق المباحة",
      "scholarly_function": "rule_statement",
      "confidence": 0.85
    },
    {
      "segment_index": 99,
      "start_word": 2446,
      "end_word": 2448,
      "text_snippet": "اختلاف العلماء:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 100,
      "start_word": 2449,
      "end_word": 2462,
      "text_snippet": "اختلف العلماء في حكم المسألة العينة، التي تقدم شرحها.",
      "scholarly_function": "structural_transition",
      "confidence": 0.88
    },
    {
      "segment_index": 101,
      "start_word": 2463,
      "end_word": 2500,
      "text_snippet": "فذهب الأئمة الثلاثة، أبو حنيفة، ومالك، وأحمد وأتباعهم: إلى تحريمها. وهو مروى عن ابن عباس، وعائشة",
      "scholarly_function": "opinion_statement",
      "confidence": 0.93
    },
    {
      "segment_index": 102,
      "start_word": 2501,
      "end_word": 2535,
      "text_snippet": "لما روى أحمد، وأبو داود عن ابن عمر قال: سمعت رسول الله صلى الله عليه وسلم يقول: \" إذَا تَبَايَعْتُمْ بِالعِينَةِ",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 103,
      "start_word": 2536,
      "end_word": 2590,
      "text_snippet": "وما رواه أحمد أيضاً [أن أم ولد زيد بن أرقم، أخبرت عائشة: أنها باعت غلاما من زيد",
      "scholarly_function": "narration",
      "confidence": 0.92
    },
    {
      "segment_index": 104,
      "start_word": 2591,
      "end_word": 2620,
      "text_snippet": "والظاهر أنها لا تقول مثل هذا باجتهاد منها، لأن هذا التغليظ لا يكون إلا بتوقيف من النبي صلى الله عليه وسلم.",
      "scholarly_function": "evidence_rational",
      "confidence": 0.88
    },
    {
      "segment_index": 105,
      "start_word": 2621,
      "end_word": 2650,
      "text_snippet": "وأجاز الشافعي بيع العينة، أخذاً بعموم ما رواه البخاري ومسلم، عن أبي سعيد، وأبى هريرة",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 106,
      "start_word": 2651,
      "end_word": 2700,
      "text_snippet": "[أن رسول الله صلى الله عليه وسلم استعمل رجلا على خيبر، فجاء بتمر جنيب [طيب] فقال رسول الله صلى الله عليه وسلم: أكُلَ تَمْرِ خَيبرَ هكَذَا؟",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 107,
      "start_word": 2701,
      "end_word": 2725,
      "text_snippet": "فقال النبي صلى الله عليه وسلم: \" لا تَفْعَلْ، بع الجَمعَ [التمر الرديء] ثُم ابتعْ بالدراهم جنيباً\".",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 108,
      "start_word": 2726,
      "end_word": 2760,
      "text_snippet": "فعموم هذا الحديث يدل على أنه لا بأس أن يكون الذي اشترى منه التمر الرديء بدراهمه، هو الذي باع عليه التمر الطيب",
      "scholarly_function": "evidence_rational",
      "confidence": 0.88
    },
    {
      "segment_index": 109,
      "start_word": 2761,
      "end_word": 2780,
      "text_snippet": "وعند الأصوليين [أن ترك الاستفصال في مقام الاحتمال ينزل منزلة العموم في المقال]",
      "scholarly_function": "rule_statement",
      "confidence": 0.85
    },
    {
      "segment_index": 110,
      "start_word": 2781,
      "end_word": 2810,
      "text_snippet": "أما [مسألة التورق] التي معناها، أن يشتري السلعة نسيئة لغير قصد الانتفاع بها، وإنما ليبيعها بثمنها",
      "scholarly_function": "definition",
      "confidence": 0.9
    },
    {
      "segment_index": 111,
      "start_word": 2811,
      "end_word": 2820,
      "text_snippet": "فالمشهور عند أصحابنا جوازها.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 112,
      "start_word": 2821,
      "end_word": 2845,
      "text_snippet": "وكان شيخنا \" عبد الرحمن السعدي \" يجيزها، ويرى عموم هذا الحديث يتناولها بالحل.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 113,
      "start_word": 2846,
      "end_word": 2920,
      "text_snippet": "وقال في أحد كتبه: \"لأن المشترى لم يبعها على البائع عليه، وعموم النصوص تدل علىجوازها",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 114,
      "start_word": 2921,
      "end_word": 2935,
      "text_snippet": "والرواية الثانية عن الإمام أحمد، التحريم، واختارها شيخ الإسلام \" ابن تيمية\".",
      "scholarly_function": "opinion_statement",
      "confidence": 0.93
    },
    {
      "segment_index": 115,
      "start_word": 2936,
      "end_word": 2980,
      "text_snippet": "وقال ابن القيم \"وكان شيخنا- ابن تيمية- رحمه الله يمنع من مسألة التورق وسئل عنها مراراً وأنا حاضر فلم يرخص فيها.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 116,
      "start_word": 2981,
      "end_word": 3005,
      "text_snippet": "وقال: المعنى الذي لأجله حرم الربا، موجود فيها بعينه، مع زيادة الكلفة بالشراء والبيع والخسارة فيها\".",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 117,
      "start_word": 3006,
      "end_word": 3040,
      "text_snippet": "والمانعون من \"العينة\" جعلوها من باب الذرائع المحرمة، وجعلوا الحديث من باب المطلق الذي يقيد بِصُوَر البيع الصحيح",
      "scholarly_function": "refutation",
      "confidence": 0.85
    },
    {
      "segment_index": 118,
      "start_word": 3041,
      "end_word": 3055,
      "text_snippet": "وهكذا إطلاقات الشارع تدل على ما أذن فيه وأباح.",
      "scholarly_function": "rule_statement",
      "confidence": 0.82
    },
    {
      "segment_index": 119,
      "start_word": 3056,
      "end_word": 3090,
      "text_snippet": "فإن قوله: \"بع الجمع\" مطلق، يقيد بالعقود الصحيحة، وليس بعام ليدخل فيه الصورة التي تعقد مع مشترى \"الجمع\"",
      "scholarly_function": "refutation",
      "confidence": 0.88
    },
    {
      "segment_index": 120,
      "start_word": 3091,
      "end_word": 3125,
      "text_snippet": "وبهذا تبين فساد قول الذين يحاولون الاستدلال على وجود الحيل في الشرع فإن الشارع لما نهاه عن معاملة محرمة",
      "scholarly_function": "refutation",
      "confidence": 0.9
    },
    {
      "segment_index": 121,
      "start_word": 3126,
      "end_word": 3145,
      "text_snippet": "ومن أراد بسط هذا، فعليه ب \" إعلام الموقعين \" لابن القيم، رحمه لله تعالى.",
      "scholarly_function": "cross_reference",
      "confidence": 0.95
    },
    {
      "segment_index": 122,
      "start_word": 3146,
      "end_word": 3148,
      "text_snippet": "الحديث الرابع",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 123,
      "start_word": 3149,
      "end_word": 3200,
      "text_snippet": "عَنْ أبي المِنْهَالِ قال: سَالتُ البَرَاءَ بنَ عازِب وَزَيْدَ بنَ أرْقمَ عَنِ الصرفِ، فَكُل وَاحِدٍ مِنْهُمَا يَقُولُ: هذَا خَير مِنىٍ",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 124,
      "start_word": 3201,
      "end_word": 3203,
      "text_snippet": "المعنى الإجمالي:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 125,
      "start_word": 3204,
      "end_word": 3230,
      "text_snippet": "سأل أبو المنهال، البراء بن عازب، وزيد ين أرقم، عن حكم الصرف، الذي هو بيع الأثمان بعضها ببعض.",
      "scholarly_function": "narration",
      "confidence": 0.85
    },
    {
      "segment_index": 126,
      "start_word": 3231,
      "end_word": 3255,
      "text_snippet": "فمن ورعهما رضى الله عنهما، أخذا يتدافعان الفتوى، ويحتقر كل واحد منهما نفسه بجانب صاحبه.",
      "scholarly_function": "narration",
      "confidence": 0.85
    },
    {
      "segment_index": 127,
      "start_word": 3256,
      "end_word": 3300,
      "text_snippet": "ولكنهما اتفقا على حفظهما: أن النبي صلى الله عليه وسلم نهى عن بيع الذهب بالفضةدَيناً، لاجتماعهما في علة الربا",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 128,
      "start_word": 3301,
      "end_word": 3306,
      "text_snippet": "ما يستفاد من الحديث:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 129,
      "start_word": 3307,
      "end_word": 3335,
      "text_snippet": "1- النهى عن بيع الذهب بالفضة، أو الفضة بالذهب، وهما أو أحدهما غائب، فلابد من التقابض في مجلس العقد.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 130,
      "start_word": 3336,
      "end_word": 3350,
      "text_snippet": "2- صحة البيع مع التقابض في مجلس العقد، لأنه صرف.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 131,
      "start_word": 3351,
      "end_word": 3380,
      "text_snippet": "3- المفسد للعقد إذا لم يحمل تقابض في المجلس، هو ما اجتمع فيه النقدان، من علة الربا.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 132,
      "start_word": 3381,
      "end_word": 3400,
      "text_snippet": "4- ما كان عليه السلف رضى الله عنهم من الورع، وتفضيل بعضهم بعضا.",
      "scholarly_function": "rule_statement",
      "confidence": 0.82
    },
    {
      "segment_index": 133,
      "start_word": 3401,
      "end_word": 3403,
      "text_snippet": "الحديث الخميس",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 134,
      "start_word": 3404,
      "end_word": 3450,
      "text_snippet": "عَنْ أبي بَكْرَةَ قَالَ: نَهَى رَسُولُ الله صلى الله عليه وسلم عَنِ الْفِضةِ بِالْفِضَّةِ. وَالذَّهَبِ بِالذَّهَبِ: إِلا سَوَاءً بِسَواءٍ.",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.98
    },
    {
      "segment_index": 135,
      "start_word": 3451,
      "end_word": 3475,
      "text_snippet": "وَأمرَنَا أنْ نَشْتَريَ الْفِضَّةَ بِالذَّهَبِ كيف شِئْنَا وَنَشْتَرِيَ الذًهَبَ بِالْفِضةِ كَيْفَ شِئْنَا.",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.95
    },
    {
      "segment_index": 136,
      "start_word": 3476,
      "end_word": 3495,
      "text_snippet": "قال: فسأله رَجل فَقَالَ: يَداً بيد؟ فَقَالَ: هكَذَا سَمِعْتُ",
      "scholarly_function": "evidence_hadith",
      "confidence": 0.92
    },
    {
      "segment_index": 137,
      "start_word": 3496,
      "end_word": 3498,
      "text_snippet": "المعنى الإجمالي:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 138,
      "start_word": 3499,
      "end_word": 3525,
      "text_snippet": "لما كان بيع الذهب بالذهب، والفضة بالفضة، متفاضلا رباً، نهى عنه ما لم يكونا متساويين، وزناً بوزن",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 139,
      "start_word": 3526,
      "end_word": 3545,
      "text_snippet": "أما بيع الذهب بالفضة، أو الفضة بالذهب، فلا بأس به، وإن كانا متفاضلين",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 140,
      "start_word": 3546,
      "end_word": 3580,
      "text_snippet": "على أنه لابد في صحة ذلك من التقابض في مجلس العقد، وإلا كان ربا النسيئة المحرم",
      "scholarly_function": "condition_exception",
      "confidence": 0.88
    },
    {
      "segment_index": 141,
      "start_word": 3581,
      "end_word": 3586,
      "text_snippet": "ما يستفاد من الحديث:",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 142,
      "start_word": 3587,
      "end_word": 3615,
      "text_snippet": "1- تحريم بيع الذهب بالذهب، والفضة بالفضة، متفاضلين، لاجتماع الثمن والمثمن، في جنس واحد من الاجناس الربوية",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 143,
      "start_word": 3616,
      "end_word": 3660,
      "text_snippet": "2- إباحة بيع الذهب بالذهب، والفضة بالفضة، بشرطين: الأول: التماثل منهما، فلا يزيد أحدهما على الآخر. والثاني: التقابض في مجلس العقد بينهما.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 144,
      "start_word": 3661,
      "end_word": 3690,
      "text_snippet": "وما يقال في الذهب والفضة، يقال في جنس واحد من الأجناس الربوية، حينما يباع بعضه ببعض، كالبر بالشعير.",
      "scholarly_function": "evidence_qiyas",
      "confidence": 0.82
    },
    {
      "segment_index": 145,
      "start_word": 3691,
      "end_word": 3720,
      "text_snippet": "3- جواز بيع الذهب بالفضة، أو الفضة بالذهب متفاضلين، لكون كل واحد منهما من جنس غر جنس الآخر.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 146,
      "start_word": 3721,
      "end_word": 3745,
      "text_snippet": "وكذا يقال في كل جنس بيع بغير جنسه من الأجناس الربوية، فلا بأس من التفاضل بينهما.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 147,
      "start_word": 3746,
      "end_word": 3775,
      "text_snippet": "4- لابد في بيع الذهب بالفضة، أو الفضة بالذهب، من التقابض بينهما في مجلس العقد.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 148,
      "start_word": 3776,
      "end_word": 3800,
      "text_snippet": "فإن تفرقا قبل القبض، بطل العقد، لاجتماعهما في العلة الربوية.",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 149,
      "start_word": 3801,
      "end_word": 3830,
      "text_snippet": "وكذا كل جنسين اتفقا فى العلة الربوية، وهى الكيل، أو الوزن مع الطعم، فلابد من التقابض بينهما في مجلس العقد.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 150,
      "start_word": 3831,
      "end_word": 3838,
      "text_snippet": "اختلاف العلماء في (الأوراق البنكية) :",
      "scholarly_function": "structural_transition",
      "confidence": 0.95
    },
    {
      "segment_index": 151,
      "start_word": 3839,
      "end_word": 3860,
      "text_snippet": "في هذه الأزمان الأخيرة، أخذ الناس يتعاملون بدل الذهب والفضة بالأوراق البنكية (الأنواط).",
      "scholarly_function": "editorial_note",
      "confidence": 0.82
    },
    {
      "segment_index": 152,
      "start_word": 3861,
      "end_word": 3878,
      "text_snippet": "فجعلوا لكل نقد (فئة) تقابلها، تحمل اسمها وقيمتها.",
      "scholarly_function": "editorial_note",
      "confidence": 0.8
    },
    {
      "segment_index": 153,
      "start_word": 3879,
      "end_word": 3900,
      "text_snippet": "فاختلف الناس في حكمها وإليك الإشارة إلى أقوالهم، بطريق الإيجاز والاختصار.",
      "scholarly_function": "structural_transition",
      "confidence": 0.88
    },
    {
      "segment_index": 154,
      "start_word": 3901,
      "end_word": 3920,
      "text_snippet": "فمنهم: من يرى أنها من بيع السندات والديون والصكوك، فحرم المعاملات بها إطلاقاً.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 155,
      "start_word": 3921,
      "end_word": 3940,
      "text_snippet": "ومنهم: من يرى أنها عروض من عروض التجارة، فلا يجرى فيها الربا بنوعيه.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 156,
      "start_word": 3941,
      "end_word": 3980,
      "text_snippet": "وهذا القول بتساهله مقابل للقول الذي قبله بشدته، الثاني يرى جواز بيع بعضها ببعض، وبيعها بأحد النقدين متفاضلة ونسيئة",
      "scholarly_function": "opinion_statement",
      "confidence": 0.88
    },
    {
      "segment_index": 157,
      "start_word": 3981,
      "end_word": 3990,
      "text_snippet": "وهذان القولان في غاية الضعف.",
      "scholarly_function": "refutation",
      "confidence": 0.9
    },
    {
      "segment_index": 158,
      "start_word": 3991,
      "end_word": 4015,
      "text_snippet": "فأما الأول: ففيه تشديد، وحرج وضيق، وطبع ديننا السماح، واليسر، خصوصاً في العادات والمعاملات.",
      "scholarly_function": "refutation",
      "confidence": 0.92
    },
    {
      "segment_index": 159,
      "start_word": 4016,
      "end_word": 4040,
      "text_snippet": "والثاني: فيه فتح لباب شر كبير، وهو الربا بأنواعه، مع أنه لا يستند إلى شيء من تعليل صحيح.",
      "scholarly_function": "refutation",
      "confidence": 0.92
    },
    {
      "segment_index": 160,
      "start_word": 4041,
      "end_word": 4060,
      "text_snippet": "ومنهم: من يرى أن حكمها، حكم النقدين، يجرى فيها ما يجرى فيهما من الأحكام.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 161,
      "start_word": 4061,
      "end_word": 4085,
      "text_snippet": "وهذا له وجه من الصحة، لقوة مأخذه، ويستدلون على ذلك بأن البدل له حكم المبدل في كل شئ.",
      "scholarly_function": "evidence_rational",
      "confidence": 0.85
    },
    {
      "segment_index": 162,
      "start_word": 4086,
      "end_word": 4105,
      "text_snippet": "وأحسن الأقوال في ذلك وأعدلها وأقربها للصواب، هو أن نجعل حكمها حكم الفلوس.",
      "scholarly_function": "opinion_statement",
      "confidence": 0.92
    },
    {
      "segment_index": 163,
      "start_word": 4106,
      "end_word": 4120,
      "text_snippet": "فنجرى فيها ربا النسيئة، ولا نجرى عليها ربا الفضل.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 164,
      "start_word": 4121,
      "end_word": 4160,
      "text_snippet": "فيجوز بيع بعضها ببعض، أو بأحد النقدين متفاضلة والمفاضلة هنا فيما تمثل من القيمة النقدية",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    },
    {
      "segment_index": 165,
      "start_word": 4161,
      "end_word": 4175,
      "text_snippet": "أما المفاضلة في ذاتها فأمر لا يتضرر، ولا يجوز ذلك نسيئة.",
      "scholarly_function": "rule_statement",
      "confidence": 0.9
    }
  ],
  "total_segments": 166
}