      "confidence": 0.97
    },
    {
      "segment_index": 13,
      "start_word": 311,
      "end_word": 340,
      "text_snippet": "37 - وإذا قلت الأكفان وكثرت الموتى جاز تكفين الجماعة منهم في الكفن الواحد",
      "scholarly_function": "rule_statement",
      "confidence": 0.92
    },
    {
